{
    "compilerOptions": {
          "module": "nodenext",
          "moduleResolution": "nodenext",
          "target": "ES2023",
          "declaration": true,
          "declarationMap": true,
          "sourceMap": true,
          "outDir": "./dist",
          "rootDir": "./src",
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"]
}
