# ─── BANCO DE DADOS (Supabase) ────────────────────────────────────────────────
# Obtenha em: https://supabase.com → Seu Projeto → Settings → Database

# Transaction mode (Pooling) - para uso geral da aplicação
DATABASE_URL="postgresql://postgres.[SEU-PROJECT-REF]:[SUA-SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection - para migrações do Prisma
DIRECT_URL="postgresql://postgres.[SEU-PROJECT-REF]:[SUA-SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── API BACKEND (Render) ─────────────────────────────────────────────────────
# URL pública da API após deploy no Render
NEXT_PUBLIC_API_URL="https://emporio-api.onrender.com"

# ─── AMBIENTE ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
